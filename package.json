{
  "name": "@mcbe-mods/create",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.1",
  "description": "CLI tool for scaffolding and developing Minecraft Bedrock Edition addons",
  "author": "Lete114",
  "license": "MIT",
  "homepage": "https://github.com/mcbe-mods/create#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcbe-mods/create.git"
  },
  "bugs": "https://github.com/mcbe-mods/create/issues",
  "keywords": [
    "minecraft",
    "bedrock",
    "addon",
    "scaffold",
    "cli"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "bin": {
    "mcbe-create": "bin/mcbe-create.js"
  },
  "files": [
    "bin",
    "dist",
    "templates"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "tsx src/index.ts",
    "release": "bumpp",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "nr build"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "@minecraft/server": "^1.11.0",
    "archiver": "^7.0.0",
    "chokidar": "^4.0.0",
    "commander": "^13.0.0",
    "fs-extra": "^11.3.0",
    "ora": "^8.1.0",
    "picocolors": "^1.1.0",
    "vite": "^8.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@antfu/ni": "^23.0.0",
    "@types/archiver": "^6.0.0",
    "@types/fs-extra": "^11.0.0",
    "@types/node": "^22.0.0",
    "bumpp": "^10.0.0",
    "eslint": "^9.0.0",
    "nano-staged": "^0.8.0",
    "publint": "^0.3.0",
    "simple-git-hooks": "^2.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm i --frozen-lockfile --ignore-scripts --offline && pnpm run build && npx nano-staged"
  },
  "nano-staged": {
    "*": "eslint --fix"
  }
}
